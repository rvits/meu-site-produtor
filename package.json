{
  "name": "meu-site-produtor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "seed": "node prisma/seed.js",
    "te:list": "npx --yes tsx --tsconfig tsconfig.json scripts/te-run.ts --list",
    "te:run": "npx --yes tsx --tsconfig tsconfig.json scripts/te-run.ts",
    "te:suite:te02a": "npx --yes tsx --tsconfig tsconfig.json scripts/te-run.ts --suite te02a",
    "te:suite:sync01a": "npx --yes tsx --tsconfig tsconfig.json scripts/te-run.ts --suite sync01a",
    "domain:audit": "npx --yes tsx --tsconfig tsconfig.json scripts/domain-audit.ts",
    "workflow:audit": "npx --yes tsx --tsconfig tsconfig.json scripts/workflow-audit.ts",
    "workflow:smoke": "npx --yes tsx --tsconfig tsconfig.json scripts/workflow-smoke.ts",
    "sync:audit": "npx --yes tsx --tsconfig tsconfig.json scripts/synchronization-audit.ts",
    "sim:list": "npx --yes tsx --tsconfig tsconfig.json scripts/sim-run.ts --list",
    "sim:run": "npx --yes tsx --tsconfig tsconfig.json scripts/sim-run.ts",
    "sim:batch": "npx --yes tsx --tsconfig tsconfig.json scripts/sim-run.ts --batch",
    "sim:cleanup": "npx --yes tsx --tsconfig tsconfig.json scripts/sim-run.ts --cleanup",
    "sim:report": "npx --yes tsx --tsconfig tsconfig.json scripts/sim-run.ts --report",
    "sim:audit": "npx --yes tsx --tsconfig tsconfig.json scripts/simulation-audit.ts",
    "migrate:postgresql": "node scripts/migrar-para-postgresql-v2.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.19.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "mercadopago": "^2.11.0",
    "next": "16.1.6",
    "nodemailer": "^7.0.11",
    "openai": "^6.10.0",
    "prisma": "^5.19.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "recharts": "^3.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.10.0",
    "better-sqlite3": "^12.6.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
